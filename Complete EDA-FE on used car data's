        "# -------------------\n",
        "# 6. Deterministic cleaning rules (examples you can follow manually)\n",
        "# -------------------\n",
        "cleaned = df.copy()\n",
        "\n",
        "# Drop S.No. if it exists\n",
        "if 'S.No.' in cleaned.columns:\n",
        "    cleaned.drop(columns=['S.No.'], inplace=True)\n",
        "\n",
        "# Flag odometer outliers and cap them at 99th percentile for modelling\n",
        "cleaned['Kilometers_Driven_flagged'] = cleaned['Kilometers_Driven'] > 500000\n",
        "odometer_99 = cleaned['Kilometers_Driven'].quantile(0.99)\n",
        "cleaned['Kilometers_Driven_capped'] = cleaned['Kilometers_Driven'].clip(upper=odometer_99)\n",
        "\n",
        "# Seats imputation (brand median -> overall median)\n",
        "cleaned['Seats_imputed'] = cleaned['Seats']\n",
        "brand_median = cleaned.groupby('Brand')['Seats_imputed'].transform('median')\n",
        "cleaned['Seats_imputed'] = cleaned['Seats_imputed'].fillna(brand_median)\n",
        "cleaned['Seats_imputed'] = cleaned['Seats_imputed'].fillna(cleaned['Seats_imputed'].median())\n",
        "\n",
        "# Price imputation: group median by brand & year then overall median\n",
        "cleaned['Price'] = pd.to_numeric(cleaned['Price'], errors='coerce')\n",
        "group_med = cleaned.groupby(['Brand','Year'])['Price'].transform('median')\n",
        "cleaned['Price_imputed'] = cleaned['Price'].fillna(group_med)\n",
        "cleaned['Price_imputed'] = cleaned['Price_imputed'].fillna(cleaned['Price_imputed'].median())\n",
        "\n",
        "# New_Price: keep parsed number and create Has_New_Price\n",
        "cleaned['Has_New_Price'] = cleaned['New_Price_lakh'].notnull().astype(int)\n",
        "mask = (cleaned['Price'].notnull()) & (cleaned['New_Price_lakh'].notnull())\n",
        "if mask.sum() >= 20:\n",
        "    median_ratio = (cleaned.loc[mask, 'Price'] / cleaned.loc[mask, 'New_Price_lakh']).median()\n",
        "    cleaned['New_Price_lakh_est'] = cleaned['New_Price_lakh'].fillna(cleaned['Price'] / median_ratio)\n",
        "else:\n",
        "    cleaned['New_Price_lakh_est'] = cleaned['New_Price_lakh']  # insufficient pairs to compute ratio\n",
        "\n",
        "# Feature engineering example:\n",
        "CURRENT_YEAR = 2025\n",
        "cleaned['Car_Age'] = CURRENT_YEAR - cleaned['Year']\n",
        "cleaned['Price_in_INR'] = cleaned['Price_imputed'] * 100000\n",
        "cleaned['Log_Price_INR'] = np.log1p(cleaned['Price_in_INR'])\n",
        "\n",
        "# Brand cleaning idea: handle multi-token brand names using known list by longest-match (example)\n",
        "known_brands_long = ['land rover','mercedes-benz','mahindra','maruti','hyundai','honda','toyota','volkswagen','ford','bmw','audi','tata','skoda','renault','chevrolet','nissan']\n",
        "def extract_brand_longform(name):\n",
        "    n = str(name).lower()\n",
        "    for kb in sorted(known_brands_long, key=lambda x: -len(x)):\n",
        "        if n.startswith(kb):\n",
        "            return kb.title()\n",
        "    return str(name).split()[0].title()\n",
        "cleaned['Brand_clean'] = cleaned['Name'].apply(extract_brand_longform)"
