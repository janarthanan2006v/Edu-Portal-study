        "\n",
        "# Brand extraction (simple heuristic: first token)\n",
        "df['Brand'] = df['Name'].astype(str).apply(lambda x: x.split()[0])\n",
        "\n",
        "# Mileage value and unit\n",
        "if 'Mileage' in df.columns:\n",
        "    df['Mileage_value'] = df['Mileage'].apply(extract_numeric_from_string)\n",
        "    df['Mileage_unit'] = df['Mileage'].apply(extract_unit_from_mileage)\n",
        "\n",
        "# Engine cc and Power bhp\n",
        "if 'Engine' in df.columns:\n",
        "    df['Engine_cc'] = df['Engine'].apply(extract_numeric_from_string)\n",
        "if 'Power' in df.columns:\n",
        "    df['Power_bhp'] = df['Power'].apply(lambda x: np.nan if (pd.isnull(x) or 'null' in str(x).lower()) else extract_numeric_from_string(x))\n",
        "\n",
        "# Seats: coerce to numeric, zero or negative -> NaN\n",
        "if 'Seats' in df.columns:\n",
        "    df['Seats'] = pd.to_numeric(df['Seats'], errors='coerce')\n",
