        "# -------------------\n",
        "# 3. Parsing helpers\n",
        "# -------------------\n",
        "def extract_numeric_from_string(s):\n",
        "    \"\"\"Extract the first numeric (int/float) from a string; returns np.nan if none.\"\"\"\n",
        "    if pd.isnull(s):\n",
        "        return np.nan\n",
        "    s = str(s).strip().replace(',', '')\n",
        "    m = re.search(r'[-+]?\\d*\\.?\\d+', s)\n",
        "    return float(m.group()) if m else np.nan\n",
        "\n",
        "def extract_unit_from_mileage(s):\n",
        "    \"\"\"Return 'kmpl' or 'km/kg' or np.nan\"\"\"\n",
        "    if pd.isnull(s):\n",
        "        return np.nan\n",
        "    s = str(s).lower()\n",
        "    unit = re.sub(r'[^a-z/]+', '', s)\n",
        "    return unit if unit != '' else np.nan\n",
        "\n",
        "def parse_new_price(s):\n",
        "    \"\"\"Parse '63.71 Lakh' -> 63.71 (lakhs).\"\"\"\n",
        "    if pd.isnull(s):\n",
        "        return np.nan\n",
        "    s = str(s).lower().replace(',', '')\n",
        "    m = re.search(r'(\\d+(\\.\\d+)?)', s)\n",
        "    return float(m.group(1)) if m else np.nan"
      ],
